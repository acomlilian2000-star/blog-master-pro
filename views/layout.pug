doctype html
html(lang="en")
  head
    title Blog-Master-Pro
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.mb-4
      .container
        a.navbar-brand(href="/dashboard") BlogMasterPro
        if currentUser
          ul.navbar-nav.ms-auto
            li.nav-item: a.nav-link Welcome, #{currentUser.firstName}
            li.nav-item: a.nav-link(href="/logout") Logout
        else
          ul.navbar-nav.ms-auto
            li.nav-item: a.nav-link(href="/login") Login
            li.nav-item: a.nav-link(href="/register") Register

    .container
      if success_msg != ''
        .alert.alert-success.alert-dismissible.fade.show #{success_msg}
      if error_msg != ''
        .alert.alert-danger.alert-dismissible.fade.show #{error_msg}
      if error != ''
        .alert.alert-danger.alert-dismissible.fade.show #{error}
      
      block content